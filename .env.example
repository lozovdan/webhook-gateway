# Copy to `.env` (git-ignored) and fill in. Compose reads `.env` automatically.

# Required: shared secret for the X-Signature HMAC. Use a long random value.
WEBHOOK_SECRET=change-me-to-a-long-random-secret

# Optional: comma-separated allowlist (defaults to USD,EUR,CZK).
# ALLOWED_CURRENCIES=USD,EUR,CZK

# Optional: replay window in seconds, positive integer (defaults to 300).
# REPLAY_TOLERANCE_SECONDS=300
